# ══════════════════════════════════════════════════════════════════
# .gitignore — Projet Astro.js (Infomaniak/FTP deployment)
# ══════════════════════════════════════════════════════════════════

# ── Dépendances ────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build (généré par CI/CD, ne pas versionner) ────────────────────
dist/
.output/

# ── Astro ──────────────────────────────────────────────────────────
.astro/

# ── Env & secrets ──────────────────────────────────────────────────
.env
.env.*
!.env.example
*.local

# ── Caches ─────────────────────────────────────────────────────────
.cache/
.eslintcache
*.tsbuildinfo
.turbo/

# ── Logs ───────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*

# ── OS ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── IDEs ───────────────────────────────────────────────────────────
.idea/
*.suo
*.sw?

# ── Divers ─────────────────────────────────────────────────────────
*.bak
*.tmp
out.txt
coverage/