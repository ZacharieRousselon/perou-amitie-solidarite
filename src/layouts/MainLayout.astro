---
import type { CollectionEntry } from 'astro:content';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  entry?: CollectionEntry<'pages'>;
}

const { title, description = "Pérou Amitié Solidarité — Association humanitaire franco-péruvienne." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Pérou Amitié Solidarité`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />

    <title>{title} | Pérou Amitié Solidarité</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body class="bg-stone-50 text-stone-800 font-sans antialiased">

    <!-- Header -->
    <header class="bg-red-800 text-white shadow-md">
      <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 hover:opacity-90 transition-opacity">
          <span class="text-2xl">🇵🇪</span>
          <div>
            <p class="font-bold text-lg leading-tight">Pérou Amitié Solidarité</p>
            <p class="text-red-200 text-xs">Ensemble pour un monde meilleur</p>
          </div>
        </a>
        <nav class="hidden md:flex gap-5 text-sm font-medium">
          <a href="/" class="hover:text-red-200 transition-colors">Accueil</a>
          <a href="/association" class="hover:text-red-200 transition-colors">L'Association</a>
          <a href="/parrainage" class="hover:text-red-200 transition-colors">Parrainage</a>
          <a href="/projets" class="hover:text-red-200 transition-colors">Projets</a>
          <a href="/don" class="hover:text-red-200 transition-colors bg-amber-500 text-white px-3 py-1 rounded-full hover:bg-amber-400">Faire un don</a>
        </nav>
      </div>
    </header>

    <!-- Contenu principal -->
    <main class="max-w-4xl mx-auto px-4 py-10 min-h-[70vh]">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-stone-800 text-stone-300 mt-16">
      <div class="max-w-5xl mx-auto px-4 py-8 flex flex-col md:flex-row justify-between items-center gap-4 text-sm">
        <p>© {new Date().getFullYear()} Pérou Amitié Solidarité — Association loi 1901</p>
        <div class="flex gap-6">
          <a href="/don" class="hover:text-white transition-colors">Faire un don</a>
          <a href="/parrainage" class="hover:text-white transition-colors">Parrainage</a>
          <a href="/contact" class="hover:text-white transition-colors">Contact</a>
          <a href="http://facebook.com/perouamitiesolidariteofficiel" target="_blank" rel="noopener" class="hover:text-white transition-colors">Facebook</a>
        </div>
      </div>
    </footer>

  </body>
</html>
