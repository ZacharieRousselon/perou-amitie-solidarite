---
import '../styles/global.css';
import { navigation } from '../data/navigation';
import { BASE, HELLOASSO_URL, FACEBOOK_URL } from '../config';

interface Props {
  title: string;
  description?: string;
  heroImage?: string;
  heroTitle?: string;
  breadcrumb?: Array<{label: string; href?: string}>;
  showPageHero?: boolean;
}

const {
  title,
  description = "Pérou Amitié Solidarité — Association humanitaire franco-péruvienne pour les enfants défavorisés.",
  heroImage,
  heroTitle,
  breadcrumb = [],
  showPageHero = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={`${title} | Pérou Amitié Solidarité`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  {heroImage && <meta property="og:image" content={heroImage} />}
  <title>{title} | Pérou Amitié Solidarité</title>
  <link rel="icon" type="image/png" href="/perou-amitie-solidarite/assets/images/favicon-logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!-- Google Fonts chargées de manière non-bloquante -->
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Playfair+Display:wght@600;700&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Playfair+Display:wght@600;700&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Playfair+Display:wght@600;700&display=swap" /></noscript>
</head>

<body>
<a href="#main-content" class="skip-link">Passer au contenu principal</a>

<!-- ══ HEADER ══════════════════════════════════════════════════════ -->
<header class="site-header">
  <div class="nav-container">

    <!-- Logo -->
    <a href="/perou-amitie-solidarite/" class="nav-logo">
      <img
        src="/perou-amitie-solidarite/assets/images/logo-perou-asso.webp"
        alt="Logo Pérou Amitié Solidarité"
        width="90"
        height="49"
        style="height:42px;width:auto;display:block"
      />
      <div class="nav-logo-text">
        <strong>Pérou Amitié Solidarité</strong>
        <span>Association humanitaire</span>
      </div>
    </a>

    <!-- Desktop nav -->
    <ul class="nav-menu" role="list">
      {navigation.map(item => (
        <li class="nav-item">
          <a href={item.href} class={`nav-link${currentPath.startsWith(item.href) ? ' active' : ''}`}>
            {item.label}
            {item.children && (
              <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor">
                <path d="M1 3L5 7L9 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"/>
              </svg>
            )}
          </a>
          {item.children && (
            <div class="nav-dropdown">
              {item.children.map((child: any) => {
                if ('section' in child) return <div class="nav-dropdown-section">{child.section}</div>;
                if ('divider' in child) return <div class="nav-divider"></div>;
                return <a href={child.href}>{child.label}</a>;
              })}
            </div>
          )}
        </li>
      ))}
      <li>
        <a href={`${BASE}/don`} class="nav-link nav-cta"><span aria-hidden="true">❤️</span> Faire un don</a>
      </li>
    </ul>

    <!-- Hamburger mobile -->
    <button class="nav-hamburger" id="hamburger" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mobile-nav">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile nav -->
<nav class="nav-mobile" id="mobile-nav" aria-hidden="true" aria-label="Menu mobile">
  <a href={`${BASE}/`} style="font-weight:700;font-size:1rem;color:#8B1919"><span aria-hidden="true">🏠</span> Accueil</a>
  {navigation.map(item => (
    <div>
      <div class="mobile-cat">{item.label}</div>
      <div class="mobile-sub">
        {item.children?.map((child: any) => {
          if ('section' in child || 'divider' in child) return null;
          return <a href={child.href}>{child.label}</a>;
        })}
      </div>
    </div>
  ))}
  <div style="padding:1rem">
    <a href={`${BASE}/don`} class="btn-primary" style="justify-content:center"><span aria-hidden="true">❤️</span> Faire un don</a>
  </div>
</nav>

<!-- ══ PAGE HERO (inner pages) ═════════════════════════════════════ -->
{showPageHero && (
  <div class="page-hero">
    <div class="page-hero-bg" style={heroImage ? `background-image:url('${heroImage}')` : 'background:#8B1919'} />
    <div class="page-hero-content">
      {breadcrumb.length > 0 && (
        <nav class="breadcrumb" aria-label="Fil d'Ariane">
          <a href="/perou-amitie-solidarite/">Accueil</a>
          {breadcrumb.map((crumb, i) => (
            <>
              <span>›</span>
              {crumb.href && i < breadcrumb.length - 1
                ? <a href={crumb.href}>{crumb.label}</a>
                : <span style="color:rgba(255,255,255,0.9)">{crumb.label}</span>
              }
            </>
          ))}
        </nav>
      )}
      <h1>{heroTitle || title}</h1>
    </div>
  </div>
)}

<!-- ══ MAIN CONTENT ════════════════════════════════════════════════ -->
<main id="main-content">
  <slot />
</main>

<!-- ══ FOOTER ══════════════════════════════════════════════════════ -->
<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">

      <div class="footer-brand">
        <h2><span aria-hidden="true">🇵🇪</span> Pérou Amitié Solidarité</h2>
        <p>Association loi 1901 fondée en 2003. Nous aidons les enfants défavorisés du bidonville de Collique (Lima) et de l'île d'Amantani grâce à vos parrainages.</p>
        <p style="font-size:0.78rem;color:#A8A29E;margin-top:0.5rem;line-height:1.6">
          Siège social : 238 route de Sentout, 33880 Baurech (Gironde)<br />
          RNA : W072002360 · SIRET : 492 075 163 00013
        </p>
      </div>

      <div class="footer-col">
        <h3>L'Association</h3>
        <a href={`${BASE}/association`}>Qui sommes-nous ?</a>
        <a href={`${BASE}/equipes`}>Nos équipes</a>
        <a href={`${BASE}/partenaires`}>Nos partenaires</a>
        <a href={`${BASE}/bilan-financier`}>Bilan financier</a>
      </div>

      <div class="footer-col">
        <h3>Agir</h3>
        <a href={`${BASE}/parrainage`}>Parrainage</a>
        <a href={`${BASE}/don`}>Faire un don</a>
        <a href={`${BASE}/benevolat`}>Bénévolat</a>
        <a href={`${BASE}/devenir-parrain`}>Devenir parrain</a>
      </div>

      <div class="footer-col">
        <h3>Zones d'action</h3>
        <a href={`${BASE}/zone-collique`}>Collique (Lima)</a>
        <a href={`${BASE}/zone-casitas`}>Casitas</a>
        <a href={`${BASE}/zone-amantani`}>Amantani</a>
        <a href={`${BASE}/projets`}>Nos projets</a>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {new Date().getFullYear()} Pérou Amitié Solidarité — Association loi 1901 — Tous droits réservés</p>
      <div style="display:flex;gap:1.25rem;align-items:center;flex-wrap:wrap">
        <a href={`${BASE}/mentions-legales`} style="color:#A8A29E;font-size:0.8rem">Mentions légales</a>
        <a href={`${BASE}/politique-confidentialite`} style="color:#A8A29E;font-size:0.8rem">Politique de confidentialité</a>
        <a href={FACEBOOK_URL} target="_blank" rel="noopener noreferrer" style="color:#A8A29E;font-size:0.82rem"><span aria-hidden="true">📘</span> Facebook</a>
        <span class="footer-badge"><span aria-hidden="true">🇵🇪</span> Depuis 2003</span>
      </div>
    </div>
  </div>
</footer>


<script>
  // ── Hamburger ────────────────────────────────────
  const btn = document.getElementById('hamburger');
  const mobileNav = document.getElementById('mobile-nav');
  btn?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(isOpen));
    mobileNav?.setAttribute('aria-hidden', String(!isOpen));
  });
  mobileNav?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      mobileNav.classList.remove('open');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });

  // ── Dropdown keyboard nav ─────────────────────────
  // Fermer dropdown actif avec Escape ou clic extérieur
  const navItems = document.querySelectorAll('.nav-item');
  navItems.forEach(item => {
    const trigger = item.querySelector('.nav-link') as HTMLAnchorElement | null;
    const dropdown = item.querySelector('.nav-dropdown') as HTMLElement | null;
    if (!trigger || !dropdown) return;

    // Ouvrir/fermer via touche Entrée ou Espace sur le lien parent
    trigger.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') {
        const isExpanded = item.classList.toggle('force-open');
        trigger.setAttribute('aria-expanded', String(isExpanded));
        if (isExpanded) {
          // Focus sur le premier lien du dropdown
          const firstLink = dropdown.querySelector('a') as HTMLAnchorElement | null;
          firstLink?.focus();
        }
        e.preventDefault();
      }
      if (e.key === 'Escape') {
        item.classList.remove('force-open');
        trigger.setAttribute('aria-expanded', 'false');
        trigger.focus();
      }
    });

    // Fermer sur Escape depuis l'intérieur du dropdown
    dropdown.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') {
        item.classList.remove('force-open');
        trigger.setAttribute('aria-expanded', 'false');
        trigger.focus();
      }
    });
  });

  // Fermer tous les dropdowns force-open au clic extérieur
  document.addEventListener('click', (e: MouseEvent) => {
    navItems.forEach(item => {
      if (!item.contains(e.target as Node)) {
        item.classList.remove('force-open');
        const t = item.querySelector('.nav-link') as HTMLAnchorElement | null;
        t?.setAttribute('aria-expanded', 'false');
      }
    });
  });

  // Fermer mobile nav sur Escape
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && mobileNav?.classList.contains('open')) {
      mobileNav.classList.remove('open');
      btn?.setAttribute('aria-expanded', 'false');
      btn?.focus();
    }
  });

  // ── Gallery post-processor ────────────────────────
  // Group consecutive <p><img></p> elements into grid galleries
  function processGalleries(container: HTMLElement) {
    const kids = [...container.children] as HTMLElement[];
    let group: HTMLElement[] = [];

    function flush() {
      if (group.length === 0) return;
      if (group.length === 1) {
        group[0].classList.add('gal-single-wrap');
        group = [];
        return;
      }
      const count = group.length;
      const cls = count === 2 ? 'gal-2' : count === 3 ? 'gal-3' : count === 4 ? 'gal-4' : 'gal-many';
      const grid = document.createElement('div');
      grid.className = `gal-grid ${cls}`;
      const first = group[0];
      first.parentNode?.insertBefore(grid, first);
      group.forEach((el, i) => {
        const slot = document.createElement('div');
        slot.className = `gal-slot gal-slot-${i}`;
        slot.appendChild(el);
        grid.appendChild(slot);
      });
      group = [];
    }

    kids.forEach(el => {
      const isImgOnly = el.tagName === 'P' && el.children.length === 1 && el.querySelector('img');
      if (isImgOnly) {
        group.push(el);
      } else {
        flush();
      }
    });
    flush();
  }

  // ── Lightbox ──────────────────────────────────────
  let lbImages: string[] = [];
  let lbIdx = 0;

  function buildLightbox() {
    if (document.getElementById('lightbox')) return;
    const lb = document.createElement('div');
    lb.id = 'lightbox';
    lb.className = 'lightbox-overlay';
    lb.setAttribute('role', 'dialog');
    lb.setAttribute('aria-modal', 'true');
    lb.innerHTML = `
      <button class="lightbox-close" id="lightbox-close" aria-label="Fermer">✕</button>
      <button class="lightbox-nav" id="lightbox-prev" aria-label="Précédent">‹</button>
      <div class="lightbox-img-wrap"><img id="lightbox-img" src="" alt="" /></div>
      <button class="lightbox-nav" id="lightbox-next" aria-label="Suivant">›</button>
      <div class="lightbox-counter" id="lightbox-counter"></div>
    `;
    document.body.appendChild(lb);

    const img = document.getElementById('lightbox-img') as HTMLImageElement;
    const counter = document.getElementById('lightbox-counter')!;

    function show(i: number) {
      lbIdx = (i + lbImages.length) % lbImages.length;
      img.src = lbImages[lbIdx];
      counter.textContent = `${lbIdx + 1} / ${lbImages.length}`;
    }

    document.getElementById('lightbox-close')?.addEventListener('click', () => lb.classList.remove('open'));
    document.getElementById('lightbox-prev')?.addEventListener('click', (e) => { e.stopPropagation(); show(lbIdx - 1); });
    document.getElementById('lightbox-next')?.addEventListener('click', (e) => { e.stopPropagation(); show(lbIdx + 1); });
    lb.addEventListener('click', (e) => { if (e.target === lb) lb.classList.remove('open'); });
    document.addEventListener('keydown', e => {
      if (!lb.classList.contains('open')) return;
      if (e.key === 'Escape') lb.classList.remove('open');
      if (e.key === 'ArrowLeft') show(lbIdx - 1);
      if (e.key === 'ArrowRight') show(lbIdx + 1);
    });

    return { show, lb };
  }

  function initLightbox() {
    const lb = buildLightbox();
    if (!lb) return;
    const allImgs = [...document.querySelectorAll('.article-body img, .mosaic img, .gal-grid img')] as HTMLImageElement[];
    lbImages = allImgs.map(i => i.src);

    allImgs.forEach((img, idx) => {
      img.style.cursor = 'zoom-in';
      img.addEventListener('click', () => {
        lbImages = allImgs.map(i => i.src);
        const overlay = document.getElementById('lightbox')!;
        overlay.classList.add('open');
        lb.show(idx);
      });
    });
  }

  // ── Carousel init ────────────────────────────────
  function initCarousels() {
    document.querySelectorAll('.carousel-wrap').forEach(wrap => {
      const track = wrap.querySelector('.carousel-track') as HTMLElement;
      const slides = wrap.querySelectorAll('.carousel-slide');
      const dots = wrap.querySelectorAll('.carousel-dot');
      if (!track || slides.length === 0) return;
      let cur = 0;
      let timer: ReturnType<typeof setInterval>;

      function go(n: number) {
        cur = (n + slides.length) % slides.length;
        track.style.transform = `translateX(-${cur * 100}%)`;
        dots.forEach((d, i) => d.classList.toggle('active', i === cur));
      }

      wrap.querySelector('.carousel-btn-prev')?.addEventListener('click', () => { go(cur - 1); resetTimer(); });
      wrap.querySelector('.carousel-btn-next')?.addEventListener('click', () => { go(cur + 1); resetTimer(); });
      dots.forEach((d, i) => d.addEventListener('click', () => { go(i); resetTimer(); }));

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      function resetTimer() {
        clearInterval(timer);
        if (!prefersReduced) timer = setInterval(() => go(cur + 1), 5000);
      }
      // Marquer slides non-actives aria-hidden
      slides.forEach((s, i) => s.setAttribute('aria-hidden', i === 0 ? 'false' : 'true'));
      const origGo = go;
      // Override go to also update aria-hidden
      (wrap as any)._go = (n: number) => {
        slides[cur]?.setAttribute('aria-hidden', 'true');
        origGo(n);
        slides[cur]?.setAttribute('aria-hidden', 'false');
      };
      go(0);
      resetTimer();
    });
  }

  // ── Run everything ────────────────────────────────
  document.addEventListener('DOMContentLoaded', () => {
    const articleBody = document.querySelector('.article-body') as HTMLElement;
    if (articleBody) processGalleries(articleBody);
    initLightbox();
    initCarousels();
  });
</script>

</body>
</html>
