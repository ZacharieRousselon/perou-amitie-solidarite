---
import '../styles/global.css';
import { navigation } from '../data/navigation';

interface Props {
  title: string;
  description?: string;
  heroImage?: string;
  heroTitle?: string;
  breadcrumb?: Array<{label: string; href?: string}>;
  showPageHero?: boolean;
}

const {
  title,
  description = "Pérou Amitié Solidarité — Association humanitaire franco-péruvienne pour les enfants défavorisés.",
  heroImage,
  heroTitle,
  breadcrumb = [],
  showPageHero = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={`${title} | Pérou Amitié Solidarité`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  {heroImage && <meta property="og:image" content={heroImage} />}
  <title>{title} | Pérou Amitié Solidarité</title>
  <link rel="icon" type="image/png" href="/perou-amitie-solidarite/assets/images/Logo-perou-asso-1024x304.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet" />
</head>

<body>

<!-- ══ HEADER ══════════════════════════════════════════════════════ -->
<header class="site-header">
  <div class="nav-container">

    <!-- Logo -->
    <a href="/perou-amitie-solidarite/" class="nav-logo">
      <span style="font-size:1.8rem">🇵🇪</span>
      <div class="nav-logo-text">
        <strong>Pérou Amitié Solidarité</strong>
        <span>Association humanitaire</span>
      </div>
    </a>

    <!-- Desktop nav -->
    <ul class="nav-menu" role="list">
      {navigation.map(item => (
        <li class="nav-item">
          <a href={item.href} class={`nav-link${currentPath.startsWith(item.href) ? ' active' : ''}`}>
            {item.label}
            {item.children && (
              <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor">
                <path d="M1 3L5 7L9 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"/>
              </svg>
            )}
          </a>
          {item.children && (
            <div class="nav-dropdown">
              {item.children.map((child: any) => {
                if ('section' in child) return <div class="nav-dropdown-section">{child.section}</div>;
                if ('divider' in child) return <div class="nav-divider"></div>;
                return <a href={child.href}>{child.label}</a>;
              })}
            </div>
          )}
        </li>
      ))}
      <li>
        <a href="/perou-amitie-solidarite/don" class="nav-link nav-cta">❤️ Faire un don</a>
      </li>
    </ul>

    <!-- Hamburger mobile -->
    <button class="nav-hamburger" id="hamburger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile nav -->
<nav class="nav-mobile" id="mobile-nav" aria-hidden="true">
  <a href="/perou-amitie-solidarite/" style="font-weight:700;font-size:1rem;color:#8B1919">🏠 Accueil</a>
  {navigation.map(item => (
    <div>
      <div class="mobile-cat">{item.label}</div>
      <div class="mobile-sub">
        {item.children?.map((child: any) => {
          if ('section' in child || 'divider' in child) return null;
          return <a href={child.href}>{child.label}</a>;
        })}
      </div>
    </div>
  ))}
  <div style="padding:1rem">
    <a href="/perou-amitie-solidarite/don" class="btn-primary" style="justify-content:center">❤️ Faire un don</a>
  </div>
</nav>

<!-- ══ PAGE HERO (inner pages) ═════════════════════════════════════ -->
{showPageHero && (
  <div class="page-hero">
    <div class="page-hero-bg" style={heroImage ? `background-image:url('${heroImage}')` : 'background:#8B1919'} />
    <div class="page-hero-content">
      {breadcrumb.length > 0 && (
        <nav class="breadcrumb" aria-label="Fil d'Ariane">
          <a href="/perou-amitie-solidarite/">Accueil</a>
          {breadcrumb.map((crumb, i) => (
            <>
              <span>›</span>
              {crumb.href && i < breadcrumb.length - 1
                ? <a href={crumb.href}>{crumb.label}</a>
                : <span style="color:rgba(255,255,255,0.9)">{crumb.label}</span>
              }
            </>
          ))}
        </nav>
      )}
      <h1>{heroTitle || title}</h1>
    </div>
  </div>
)}

<!-- ══ MAIN CONTENT ════════════════════════════════════════════════ -->
<main>
  <slot />
</main>

<!-- ══ FOOTER ══════════════════════════════════════════════════════ -->
<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">

      <div class="footer-brand">
        <h2>🇵🇪 Pérou Amitié Solidarité</h2>
        <p>Association loi 1901 fondée en 2003. Nous aidons les enfants défavorisés du bidonville de Collique (Lima) et de l'île d'Amantani grâce à vos parrainages.</p>
        <p style="font-size:0.78rem;color:#78716C">Siège social : Baurech, Gironde (33)</p>
      </div>

      <div class="footer-col">
        <h3>L'Association</h3>
        <a href="/perou-amitie-solidarite/association">Qui sommes-nous ?</a>
        <a href="/perou-amitie-solidarite/equipes">Nos équipes</a>
        <a href="/perou-amitie-solidarite/partenaires">Nos partenaires</a>
        <a href="/perou-amitie-solidarite/bilan-financier">Bilan financier</a>
      </div>

      <div class="footer-col">
        <h3>Agir</h3>
        <a href="/perou-amitie-solidarite/parrainage">Parrainage</a>
        <a href="/perou-amitie-solidarite/don">Faire un don</a>
        <a href="/perou-amitie-solidarite/benevolat">Bénévolat</a>
        <a href="/perou-amitie-solidarite/devenir-parrain">Devenir parrain</a>
      </div>

      <div class="footer-col">
        <h3>Zones d'action</h3>
        <a href="/perou-amitie-solidarite/zone-collique">Collique (Lima)</a>
        <a href="/perou-amitie-solidarite/zone-casitas">Casitas</a>
        <a href="/perou-amitie-solidarite/zone-amantani">Amantani</a>
        <a href="/perou-amitie-solidarite/projets">Nos projets</a>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {new Date().getFullYear()} Pérou Amitié Solidarité — Association loi 1901 — Tous droits réservés</p>
      <div style="display:flex;gap:1rem;align-items:center">
        <a href="https://www.facebook.com/perouamitiesolidariteofficiel" target="_blank" rel="noopener" style="color:#A8A29E;font-size:0.82rem">Facebook</a>
        <span class="footer-badge">🇵🇪 Depuis 2003</span>
      </div>
    </div>
  </div>
</footer>


<script>
  // ── Hamburger ────────────────────────────────────
  const btn = document.getElementById('hamburger');
  const mobileNav = document.getElementById('mobile-nav');
  btn?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(isOpen));
    mobileNav?.setAttribute('aria-hidden', String(!isOpen));
  });
  mobileNav?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      mobileNav.classList.remove('open');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });

  // ── Gallery post-processor ────────────────────────
  // Group consecutive <p><img></p> elements into grid galleries
  function processGalleries(container: HTMLElement) {
    const kids = [...container.children] as HTMLElement[];
    let group: HTMLElement[] = [];

    function flush() {
      if (group.length === 0) return;
      if (group.length === 1) {
        group[0].classList.add('gal-single-wrap');
        group = [];
        return;
      }
      const count = group.length;
      const cls = count === 2 ? 'gal-2' : count === 3 ? 'gal-3' : count === 4 ? 'gal-4' : 'gal-many';
      const grid = document.createElement('div');
      grid.className = `gal-grid ${cls}`;
      const first = group[0];
      first.parentNode?.insertBefore(grid, first);
      group.forEach((el, i) => {
        const slot = document.createElement('div');
        slot.className = `gal-slot gal-slot-${i}`;
        slot.appendChild(el);
        grid.appendChild(slot);
      });
      group = [];
    }

    kids.forEach(el => {
      const isImgOnly = el.tagName === 'P' && el.children.length === 1 && el.querySelector('img');
      if (isImgOnly) {
        group.push(el);
      } else {
        flush();
      }
    });
    flush();
  }

  // ── Lightbox ──────────────────────────────────────
  let lbImages: string[] = [];
  let lbIdx = 0;

  function buildLightbox() {
    if (document.getElementById('lightbox')) return;
    const lb = document.createElement('div');
    lb.id = 'lightbox';
    lb.className = 'lightbox-overlay';
    lb.setAttribute('role', 'dialog');
    lb.setAttribute('aria-modal', 'true');
    lb.innerHTML = `
      <button class="lightbox-close" id="lightbox-close" aria-label="Fermer">✕</button>
      <button class="lightbox-nav" id="lightbox-prev" aria-label="Précédent">‹</button>
      <div class="lightbox-img-wrap"><img id="lightbox-img" src="" alt="" /></div>
      <button class="lightbox-nav" id="lightbox-next" aria-label="Suivant">›</button>
      <div class="lightbox-counter" id="lightbox-counter"></div>
    `;
    document.body.appendChild(lb);

    const img = document.getElementById('lightbox-img') as HTMLImageElement;
    const counter = document.getElementById('lightbox-counter')!;

    function show(i: number) {
      lbIdx = (i + lbImages.length) % lbImages.length;
      img.src = lbImages[lbIdx];
      counter.textContent = `${lbIdx + 1} / ${lbImages.length}`;
    }

    document.getElementById('lightbox-close')?.addEventListener('click', () => lb.classList.remove('open'));
    document.getElementById('lightbox-prev')?.addEventListener('click', (e) => { e.stopPropagation(); show(lbIdx - 1); });
    document.getElementById('lightbox-next')?.addEventListener('click', (e) => { e.stopPropagation(); show(lbIdx + 1); });
    lb.addEventListener('click', (e) => { if (e.target === lb) lb.classList.remove('open'); });
    document.addEventListener('keydown', e => {
      if (!lb.classList.contains('open')) return;
      if (e.key === 'Escape') lb.classList.remove('open');
      if (e.key === 'ArrowLeft') show(lbIdx - 1);
      if (e.key === 'ArrowRight') show(lbIdx + 1);
    });

    return { show, lb };
  }

  function initLightbox() {
    const lb = buildLightbox();
    if (!lb) return;
    const allImgs = [...document.querySelectorAll('.article-body img, .mosaic img, .gal-grid img')] as HTMLImageElement[];
    lbImages = allImgs.map(i => i.src);

    allImgs.forEach((img, idx) => {
      img.style.cursor = 'zoom-in';
      img.addEventListener('click', () => {
        lbImages = allImgs.map(i => i.src);
        const overlay = document.getElementById('lightbox')!;
        overlay.classList.add('open');
        lb.show(idx);
      });
    });
  }

  // ── Carousel init ────────────────────────────────
  function initCarousels() {
    document.querySelectorAll('.carousel-wrap').forEach(wrap => {
      const track = wrap.querySelector('.carousel-track') as HTMLElement;
      const slides = wrap.querySelectorAll('.carousel-slide');
      const dots = wrap.querySelectorAll('.carousel-dot');
      if (!track || slides.length === 0) return;
      let cur = 0;
      let timer: ReturnType<typeof setInterval>;

      function go(n: number) {
        cur = (n + slides.length) % slides.length;
        track.style.transform = `translateX(-${cur * 100}%)`;
        dots.forEach((d, i) => d.classList.toggle('active', i === cur));
      }

      wrap.querySelector('.carousel-btn-prev')?.addEventListener('click', () => { go(cur - 1); resetTimer(); });
      wrap.querySelector('.carousel-btn-next')?.addEventListener('click', () => { go(cur + 1); resetTimer(); });
      dots.forEach((d, i) => d.addEventListener('click', () => { go(i); resetTimer(); }));

      function resetTimer() { clearInterval(timer); timer = setInterval(() => go(cur + 1), 5000); }
      go(0);
      resetTimer();
    });
  }

  // ── Run everything ────────────────────────────────
  document.addEventListener('DOMContentLoaded', () => {
    const articleBody = document.querySelector('.article-body') as HTMLElement;
    if (articleBody) processGalleries(articleBody);
    initLightbox();
    initCarousels();
  });
</script>

</body>
</html>
