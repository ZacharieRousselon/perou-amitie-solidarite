---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import ParrainageForm from '../components/ParrainageForm.astro';
import {
  CHILDREN_MAP,
  HERO_MAP,
  SIDEBAR_NAV,
  CAROUSEL_MAP,
  FORM_TYPE,
  FORM_PRICE,
  THIN_THRESHOLD,
} from '../data/pageConfig';
import { BASE, HELLOASSO_URL } from '../config';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages
    .filter(e => e.id !== 'index')
    .map(e => ({ params: { slug: e.id }, props: { entry: e } }));
}

interface Props { entry: CollectionEntry<'pages'>; }
const { entry } = Astro.props;
const { Content } = await render(entry);

// ── Dérivées de la page ──────────────────────────────────────────────────────
const rawBody       = entry.body ?? '';
const isThin        = rawBody.trim().length < THIN_THRESHOLD;
const children      = CHILDREN_MAP[entry.id] ?? [];
const heroImg       = HERO_MAP[entry.id];
const heroImgUrl    = heroImg ? `${BASE}/assets/images/${heroImg}` : undefined;
const sidebar       = SIDEBAR_NAV[entry.id];
const title         = entry.data.title;
const currentPath   = `${BASE}/${entry.id}`;
const carouselSlides = CAROUSEL_MAP[entry.id] ?? [];
const formType      = FORM_TYPE[entry.id];
const formPrice     = FORM_PRICE[entry.id];
const isDon         = entry.id === 'don';

// ── SEO : description auto depuis le contenu ─────────────────────────────────
const autoDesc = rawBody
  .replace(/^---[\s\S]*?---/, '')
  .replace(/#{1,6}\s+/g, '')
  .replace(/[>!\[\]*`_]/g, '')
  .replace(/\n+/g, ' ')
  .trim()
  .slice(0, 155);
const pageDescription = entry.data.description
  || autoDesc
  || `Découvrez notre page sur ${title} — Association Pérou Amitié Solidarité.`;

// ── SEO : og:image avec fallback ─────────────────────────────────────────────
const ogImage = heroImgUrl ?? `${BASE}/assets/images/Logo-perou-asso-1024x304.png`;
---

<MainLayout
  title={title}
  description={pageDescription}
  heroImage={ogImage}
  heroTitle={title}
  showPageHero={true}
  breadcrumb={[{ label: title }]}
>

<div class="article-layout">
  <main>

    {isThin && children.length > 0 ? (
      /* ── Page-menu : grille de navigation ── */
      <div>
        <p style="color:#78716C;font-size:1.05rem;margin-bottom:2rem">Choisissez une rubrique :</p>
        <div class="menu-grid">
          {children.map(child => (
            <a href={`${BASE}/${child.slug}`} class="menu-card">
              {child.img && (
                <img
                  src={`${BASE}/assets/images/${child.img}`}
                  alt={child.title}
                  width="400" height="225"
                  loading="lazy" decoding="async"
                  style="width:100%;height:140px;object-fit:cover;border-radius:8px;margin-bottom:1rem;display:block"
                />
              )}
              <div class="menu-card-icon" aria-hidden="true">{child.icon}</div>
              <h2>{child.title}</h2>
              <p>{child.desc}</p>
              <span class="menu-card-arrow">Voir la rubrique →</span>
            </a>
          ))}
        </div>
        {formType && <ParrainageForm type={formType} price={formPrice} />}
      </div>
    ) : (

      /* ── Page avec contenu Markdown ── */
      <article class="article-body content-prose">

        {/* Carousel (si disponible pour cette page) */}
        {carouselSlides.length > 0 && (
          <div
            class="carousel-wrap"
            style="margin-bottom:2rem"
            role="region"
            aria-roledescription="carousel"
            aria-label={`Galerie photos — ${title}`}
          >
            <div class="carousel-track" aria-live="off">
              {carouselSlides.map((slide, i) => (
                <div
                  class="carousel-slide"
                  role="group"
                  aria-roledescription="slide"
                  aria-label={`${i + 1} sur ${carouselSlides.length}`}
                  aria-hidden={i !== 0 ? 'true' : 'false'}
                >
                  <img
                    src={`${BASE}/assets/images/${slide.img}`}
                    alt={slide.caption ?? title}
                    width="1024" height="576"
                    loading={i === 0 ? 'eager' : 'lazy'}
                    decoding="async"
                    onerror="this.parentElement.style.display='none'"
                  />
                  {slide.caption && <div class="carousel-caption" aria-hidden="true">{slide.caption}</div>}
                </div>
              ))}
            </div>
            <button class="carousel-btn carousel-btn-prev" aria-label="Diapositive précédente">‹</button>
            <button class="carousel-btn carousel-btn-next" aria-label="Diapositive suivante">›</button>
            <div class="carousel-dots" role="tablist" aria-label="Sélectionner une diapositive">
              {carouselSlides.map((_, i) => (
                <button
                  class={`carousel-dot${i === 0 ? ' active' : ''}`}
                  role="tab"
                  aria-label={`Diapositive ${i + 1}`}
                  aria-selected={i === 0 ? 'true' : 'false'}
                ></button>
              ))}
            </div>
          </div>
        )}

        {/* Page DON — traitement spécial */}
        {isDon && (
          <div>
            <div class="helloasso-banner">
              <div class="helloasso-logo" aria-hidden="true">💚</div>
              <div class="helloasso-text">
                <h3>Faire un don en ligne via HelloAsso</h3>
                <p>HelloAsso est une plateforme associative 100% gratuite. Vos dons sont sécurisés et déductibles à 66% de votre impôt sur le revenu.</p>
              </div>
              <a href={HELLOASSO_URL} target="_blank" rel="noopener noreferrer" class="helloasso-btn">
                <span aria-hidden="true">💚</span> Donner sur HelloAsso
              </a>
            </div>
            <div class="don-options">
              <a href={HELLOASSO_URL} target="_blank" rel="noopener noreferrer" class="don-option">
                <div class="don-option-icon" aria-hidden="true">💳</div>
                <h3>Don en ligne</h3>
                <p>Par carte bancaire via HelloAsso — immédiat et sécurisé</p>
              </a>
              <div class="don-option">
                <div class="don-option-icon" aria-hidden="true">🏦</div>
                <h3>Virement bancaire</h3>
                <p>Contactez-nous pour obtenir les coordonnées bancaires</p>
              </div>
              <div class="don-option">
                <div class="don-option-icon" aria-hidden="true">✉️</div>
                <h3>Chèque postal</h3>
                <p>À l'ordre de "Pérou Amitié Solidarité" — 238 route de Sentout, 33880 Baurech</p>
              </div>
              <a href={`${BASE}/parrainage`} class="don-option">
                <div class="don-option-icon" aria-hidden="true">❤️</div>
                <h3>Parrainage</h3>
                <p>Engagez-vous sur la durée — dès 25€/mois</p>
              </a>
            </div>
            <p style="background:#FEF9C3;border:1px solid #FDE047;border-radius:10px;padding:1rem 1.25rem;font-size:0.875rem;color:#713F12;margin:1.5rem 0">
              🧾 <strong>Déduction fiscale :</strong> Vos dons sont déductibles à hauteur de 66% de votre impôt sur le revenu dans la limite de 20% du revenu imposable. Vous recevrez un reçu fiscal.
            </p>
            <Content />
            <ParrainageForm type="don" />
          </div>
        )}

        {/* Contenu Markdown standard */}
        {!isDon && <Content />}

        {/* Formulaire parrainage (pages riches) */}
        {formType && !isDon && (
          <div style="margin-top:2.5rem;padding-top:2rem;border-top:2px solid #F5EFE6">
            <h2 style="font-family:'Playfair Display',serif;font-size:1.6rem;font-weight:700;margin-bottom:0.5rem">
              Vous êtes intéressé(e) ?
            </h2>
            <p style="color:#78716C;margin-bottom:1.5rem">Remplissez ce formulaire et nous vous recontacterons rapidement.</p>
            <ParrainageForm type={formType} price={formPrice} />
          </div>
        )}

      </article>
    )}

  </main>

  {/* Sidebar */}
  <aside class="article-sidebar" aria-label="Navigation et actions">

    {sidebar && (
      <nav class="sidebar-box" aria-label={sidebar.title}>
        <div class="sidebar-box-title">{sidebar.title}</div>
        <div class="sidebar-box-links">
          {sidebar.links.map(link => (
            <a
              href={link.href}
              class={currentPath === link.href ? 'active' : ''}
              aria-current={currentPath === link.href ? 'page' : undefined}
            >
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" style="flex-shrink:0;opacity:0.5">
                <path d="M5 3L9 7L5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              {link.label}
            </a>
          ))}
        </div>
      </nav>
    )}

    {isDon ? (
      <div class="sidebar-cta" style="background:linear-gradient(135deg,#1B4332,#2D6A4F)">
        <h3><span aria-hidden="true">💚</span> HelloAsso</h3>
        <p>Plateforme associative 100% gratuite et sécurisée</p>
        <a href={HELLOASSO_URL} target="_blank" rel="noopener noreferrer" style="background:white;color:#1B4332">
          Donner maintenant →
        </a>
      </div>
    ) : (
      <div class="sidebar-cta">
        <h3><span aria-hidden="true">❤️</span> Agir maintenant</h3>
        <p>Un parrainage à partir de 25€/mois suffit à changer la vie d'un enfant.</p>
        <a href={`${BASE}/parrainage`}>Parrainer un enfant</a>
      </div>
    )}

    <div class="sidebar-box">
      <div class="sidebar-box-title">Don en ligne</div>
      <div class="sidebar-box-links">
        <a href={HELLOASSO_URL} target="_blank" rel="noopener noreferrer">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" style="flex-shrink:0;opacity:0.5">
            <path d="M5 3L9 7L5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span aria-hidden="true">💚</span> Donner sur HelloAsso
        </a>
        <a href={`${BASE}/devenir-parrain`}>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" style="flex-shrink:0;opacity:0.5">
            <path d="M5 3L9 7L5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          Devenir parrain / marraine
        </a>
        <a href={`${BASE}/benevolat`}>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" style="flex-shrink:0;opacity:0.5">
            <path d="M5 3L9 7L5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          Partir en mission
        </a>
      </div>
    </div>

    {entry.data.source && (
      <p style="font-size:0.72rem;color:#A8A29E;line-height:1.5;margin-top:0.5rem">
        Source :
        <a
          href={entry.data.source}
          target="_blank"
          rel="noopener noreferrer"
          style="color:inherit;text-decoration:underline"
        >
          {entry.data.source}
        </a>
      </p>
    )}

  </aside>
</div>

</MainLayout>
