---
import MainLayout from '../layouts/MainLayout.astro';
import Img from '../components/Img.astro';
import { BASE, HELLOASSO_URL } from '../config';
---

<MainLayout
  title="Accueil"
  description="Pérou Amitié Solidarité — Association humanitaire franco-péruvienne. Depuis 2003, nous aidons les enfants défavorisés de Collique et d'Amantani."
>

<!-- ══ HERO ══════════════════════════════════════════════════════ -->
<section class="hero">
  <div class="hero-bg hero-ken-burns" style={`background-image:url('${BASE}/assets/images/reg-cus-ville001-1280x800.jpeg')`}></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <span class="hero-tag">Association humanitaire · Depuis 2003</span>
    <h1>Ensemble pour les enfants du Pérou</h1>
    <p class="hero-desc">
      Nous soutenons les enfants défavorisés du bidonville de Collique
      et de l'île d'Amantani grâce à vos parrainages, vos dons et votre engagement.
    </p>
    <div class="hero-actions">
      <a href={`${BASE}/parrainage`} class="btn-primary">Devenir parrain</a>
      <a href={`${BASE}/don`} class="btn-secondary">Faire un don</a>
    </div>
    <div class="hero-trust">
      <span>🔒 100% des dons sur le terrain</span>
      <span>📋 Déclaration fiscale fournie</span>
      <span>🇫🇷 Asso loi 1901 — Gironde</span>
    </div>
  </div>
</section>

<!-- ══ STATS ═════════════════════════════════════════════════════ -->
<div class="stats-bar">
  <div class="stats-inner">
    <div class="stat-item">
      <div class="stat-value" data-count="2003" data-suffix="">2003</div>
      <div class="stat-label">Année de Création</div>
    </div>
    <div class="stat-item">
      <div class="stat-value" data-count="130" data-suffix="+">130+</div>
      <div class="stat-label">Enfants Parrainés</div>
    </div>
    <div class="stat-item">
      <div class="stat-value" data-count="2" data-suffix="">2</div>
      <div class="stat-label">Zones d'Action</div>
    </div>
    <div class="stat-item">
      <div class="stat-value" data-count="20" data-suffix="+">20+</div>
      <div class="stat-label">Ans d'Engagement</div>
    </div>
  </div>
</div>

<!-- ══ MISSION ═══════════════════════════════════════════════════ -->
<section class="section bg-white">
  <div class="section-inner">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:3.5rem; align-items:center">
      <div>
        <span class="section-tag">Notre Mission</span>
        <h2 class="section-title">Donner un avenir à chaque enfant</h2>
        <p class="section-subtitle" style="margin-bottom:1.25rem">
          L'association Pérou Amitié Solidarité est une ONG humanitaire fondée en 2003 par Ysabel Paire-Ficout,
          installée en Gironde. Elle agit pour améliorer les conditions de vie et d'éducation des enfants
          les plus défavorisés du Pérou.
        </p>
        <p style="color:var(--text-muted);font-size:1rem;line-height:1.75;margin-bottom:1.75rem">
          À Collique, bidonville au nord de Lima, et sur l'île d'Amantani du lac Titicaca,
          nous finançons des repas quotidiens, la scolarité, des fournitures et des projets d'infrastructure.
        </p>
        <a href={`${BASE}/association`} class="btn-red">Découvrir l'association</a>
      </div>
      <div style="position:relative">
        <Img
          src={`${BASE}/assets/images/imgp2516.jpg`}
          alt="Vue aérienne du quartier de Collique à Lima — habitat densifié sur les flancs des collines désertiques"
          width={600} height={450}
          loading="eager"
          style="width:100%;border-radius:16px;box-shadow:var(--shadow-lg)"
        />
        <div class="price-badge">
          <div class="price-badge-value">26€</div>
          <div class="price-badge-label">par mois pour un repas<br>chaque jour</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ ZONES D'ACTION ════════════════════════════════════════════ -->
<section class="section bg-cream">
  <div class="section-inner">
    <div style="margin-bottom:3rem">
      <span class="section-tag">Nos zones d'intervention</span>
      <h2 class="section-title">Où nous agissons</h2>
    </div>
    <div class="grid-3">
      <!-- Collique : carte géo avec teinture rouge marque -->
      <a href={`${BASE}/zone-collique`} class="zone-card zone-card-map zone-card-collique reveal">
        <div class="zone-map-bg" style={`background-image:url('${BASE}/assets/images/Map_of_Lima_highlighting_Comas-2.png')`} aria-hidden="true"></div>
        <div class="zone-card-overlay">
          <div class="zone-card-icon" aria-hidden="true">📍</div>
          <h3>Collique · Lima</h3>
          <p>Bidonville au nord de Lima — repas, casitas, santé</p>
          <span class="zone-card-cta">Découvrir →</span>
        </div>
      </a>
      <!-- Casitas : vraie photo terrain -->
      <a href={`${BASE}/zone-casitas`} class="zone-card reveal" style="--delay:0.1s">
        <Img src={`${BASE}/assets/images/20429586_1447639341992507_3194714572492583571_n.jpg`} alt="Repas du midi au Comedor de Collique — enfants attablés en rangées dans la salle aux murs verts, inscription ‘Niños Apadrinados Amigos del Mundo’" width={400} height={300} loading="lazy" />
        <div class="zone-card-overlay">
          <div class="zone-card-icon" aria-hidden="true">🏫</div>
          <h3>Les Casitas</h3>
          <p>Classes maternelles et soutien scolaire à Collique</p>
          <span class="zone-card-cta">Découvrir →</span>
        </div>
      </a>
      <!-- Amantani : carte géo avec teinture bleue Titicaca -->
      <a href={`${BASE}/zone-amantani`} class="zone-card zone-card-map zone-card-amantani reveal" style="--delay:0.2s">
        <div class="zone-map-bg" style={`background-image:url('${BASE}/assets/images/400px-Localizacion_de_Amantani-2.jpg')`} aria-hidden="true"></div>
        <div class="zone-card-overlay">
          <div class="zone-card-icon" aria-hidden="true">🏝️</div>
          <h3>Amantani · Titicaca</h3>
          <p>Île du lac Titicaca — collège Miguel Grau</p>
          <span class="zone-card-cta">Découvrir →</span>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- ══ PARRAINAGE ════════════════════════════════════════════════ -->
<section class="section bg-white">
  <div class="section-inner">
    <div style="text-align:center;margin-bottom:3rem">
      <span class="section-tag">Agir concrètement</span>
      <h2 class="section-title">Les types de parrainage</h2>
      <p class="section-subtitle" style="margin:0 auto">
        Chaque parrainage a un impact direct et mesurable sur la vie d'un enfant.
      </p>
    </div>

    <div class="grid-3" style="margin-bottom:2.5rem">
      <!-- Repas -->
      <a href={`${BASE}/parrainage-repas`} class="card">
        <Img src={`${BASE}/assets/images/Repas.png`} alt="Petite fille mangeant un repas de lentilles et légumes au Comedor — parrainage repas à 26€/mois" class="card-img" width={400} height={250} loading="lazy" style="object-fit:contain;background:#FEF3C7;padding:1rem" />
        <div class="card-body">
          <span class="card-tag">Repas quotidien</span>
          <div class="parain-price" style="font-size:2rem;margin-bottom:0.25rem">26€ <span style="font-size:0.9rem">/mois</span></div>
          <p class="card-desc">
            Offrez un repas chaud complet du lundi au samedi. Pour certains enfants,
            ce sera le seul repas de la journée.
          </p>
          <div class="card-arrow">En savoir plus <span>→</span></div>
        </div>
      </a>

      <!-- Études -->
      <a href={`${BASE}/parrainage-etudes`} class="card">
        <Img src={`${BASE}/assets/images/IMG_20221103_114325-1-1024x768.jpg`} alt="Maternelle des Casitas — institutrice et sept enfants en survêtements rouge-gris posant avec des loupes dans une salle de jeux" class="card-img" width={400} height={300} loading="lazy" />
        <div class="card-body">
          <span class="card-tag">Scolarité</span>
          <div class="parain-price" style="font-size:2rem;margin-bottom:0.25rem">35€+ <span style="font-size:0.9rem">/mois</span></div>
          <p class="card-desc">
            Financez la scolarité d'un enfant — accompagnement pédagogique, lycée,
            études supérieures.
          </p>
          <div class="card-arrow">En savoir plus <span>→</span></div>
        </div>
      </a>

      <!-- Maîtresse -->
      <a href={`${BASE}/parrainage-maitresse`} class="card">
        <Img src={`${BASE}/assets/images/IMG_20221104_115245-768x1024.jpg`} alt="Institutrice de la casita PRONOEI entourée de six enfants en uniforme bleu marine dans la salle de classe décorée" class="card-img" width={400} height={533} loading="lazy" />
        <div class="card-body">
          <span class="card-tag">Enseignement</span>
          <div class="parain-price" style="font-size:2rem;margin-bottom:0.25rem">25€ <span style="font-size:0.9rem">/mois</span></div>
          <p class="card-desc">
            Soutenez une institutrice des casitas — garantissez un encadrement
            pédagogique de qualité.
          </p>
          <div class="card-arrow">En savoir plus <span>→</span></div>
        </div>
      </a>
    </div>

    <div style="text-align:center">
      <a href={`${BASE}/devenir-parrain`} class="btn-red">Devenir parrain ou marraine</a>
    </div>
  </div>
</section>

<!-- ══ GALLERY + CAROUSEL ═══════════════════════════════════════ -->
<section class="section bg-stone">
  <div class="section-inner">
    <div style="margin-bottom:2rem;display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:1rem">
      <div>
        <span class="section-tag">Sur le terrain</span>
        <h2 class="section-title" style="margin-bottom:0">Nos actions en images</h2>
      </div>
