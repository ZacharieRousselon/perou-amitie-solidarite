---
import MainLayout from '../layouts/MainLayout.astro';
import Img from '../components/Img.astro';
import { BASE, HELLOASSO_URL } from '../config';
---

<MainLayout
  title="Accueil"
  description="Pérou Amitié Solidarité — Association humanitaire franco-péruvienne. Depuis 2003, nous aidons les enfants défavorisés de Collique et d'Amantani."
>

<!-- ══ HERO ══════════════════════════════════════════════════════ -->
<section class="hero">
  <div class="hero-bg" style={`background-image:url('${BASE}/assets/images/reg-cus-ville001-1280x800.jpeg')`}></div>
  <div class="hero-content">
    <span class="hero-tag">Association humanitaire · Depuis 2003</span>
    <h1>Ensemble pour les enfants du Pérou</h1>
    <p class="hero-desc">
      Nous soutenons les enfants défavorisés du bidonville de Collique
      et de l'île d'Amantani grâce à vos parrainages, vos dons et votre engagement.
    </p>
    <div class="hero-actions">
      <a href={`${BASE}/parrainage`} class="btn-primary">Devenir parrain</a>
      <a href={`${BASE}/don`} class="btn-secondary">Faire un don</a>
    </div>
  </div>
</section>

<!-- ══ STATS ═════════════════════════════════════════════════════ -->
<div class="stats-bar">
  <div class="stats-inner">
    <div><div class="stat-value">2003</div><div class="stat-label">Année de Création</div></div>
    <div><div class="stat-value">130+</div><div class="stat-label">Enfants Parrainés</div></div>
    <div><div class="stat-value">2</div><div class="stat-label">Zones d'Action</div></div>
    <div><div class="stat-value">20+</div><div class="stat-label">Ans d'Engagement</div></div>
  </div>
</div>

<!-- ══ MISSION ═══════════════════════════════════════════════════ -->
<section class="section bg-white">
  <div class="section-inner">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:3.5rem; align-items:center">
      <div>
        <span class="section-tag">Notre Mission</span>
        <h2 class="section-title">Donner un avenir à chaque enfant</h2>
        <p class="section-subtitle" style="margin-bottom:1.25rem">
          L'association Pérou Amitié Solidarité est une ONG humanitaire fondée en 2003 par Ysabel Paire-Ficout,
          installée en Gironde. Elle agit pour améliorer les conditions de vie et d'éducation des enfants
          les plus défavorisés du Pérou.
        </p>
        <p style="color:#78716C;font-size:1rem;line-height:1.75;margin-bottom:1.75rem">
          À Collique, bidonville au nord de Lima, et sur l'île d'Amantani du lac Titicaca,
          nous finançons des repas quotidiens, la scolarité, des fournitures et des projets d'infrastructure.
        </p>
        <a href={`${BASE}/association`} class="btn-red">Découvrir l'association</a>
      </div>
      <div style="position:relative">
        <Img
          src={`${BASE}/assets/images/imgp2516.jpg`}
          alt="Enfants de Collique soutenus par l'association"
          width={600} height={450}
          loading="eager"
          style="width:100%;border-radius:16px;box-shadow:0 20px 60px rgba(0,0,0,0.15)"
        />
        <div style="position:absolute;bottom:-1rem;left:-1rem;background:white;border-radius:12px;padding:1rem 1.25rem;box-shadow:0 8px 24px rgba(0,0,0,0.12)">
          <div style="font-size:1.5rem;font-weight:900;color:#8B1919">26€</div>
          <div style="font-size:0.75rem;color:#78716C;font-weight:500">par mois pour un repas<br>chaque jour</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ ZONES D'ACTION ════════════════════════════════════════════ -->
<section class="section bg-cream">
  <div class="section-inner">
    <div style="margin-bottom:3rem">
      <span class="section-tag">Nos zones d'intervention</span>
      <h2 class="section-title">Où nous agissons</h2>
    </div>
    <div class="grid-3">
      <a href={`${BASE}/zone-collique`} class="zone-card">
        <Img src={`${BASE}/assets/images/Map_of_Lima_highlighting_Comas-2.png`} alt="Quartier de Collique à Lima" width={400} height={300} loading="lazy" style="object-fit:contain;background:#f5f5f4" />
        <div class="zone-card-overlay">
          <h3>Collique · Lima</h3>
          <p>Bidonville au nord de Lima — repas, casitas, santé</p>
        </div>
      </a>
      <a href={`${BASE}/zone-casitas`} class="zone-card">
        <Img src={`${BASE}/assets/images/20429586_1447639341992507_3194714572492583571_n.jpg`} alt="Les Casitas — soutien scolaire" width={400} height={300} loading="lazy" />
        <div class="zone-card-overlay">
          <h3>Les Casitas</h3>
          <p>Classes maternelles et soutien scolaire à Collique</p>
        </div>
      </a>
      <a href={`${BASE}/zone-amantani`} class="zone-card">
        <Img src={`${BASE}/assets/images/400px-Localizacion_de_Amantani-2.jpg`} alt="Île d'Amantani sur le lac Titicaca" width={400} height={300} loading="lazy" style="object-fit:contain;background:#e0f2fe" />
        <div class="zone-card-overlay">
          <h3>Amantani · Titicaca</h3>
          <p>Île du lac Titicaca — collège Miguel Grau</p>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- ══ PARRAINAGE ════════════════════════════════════════════════ -->
<section class="section bg-white">
  <div class="section-inner">
    <div style="text-align:center;margin-bottom:3rem">
      <span class="section-tag">Agir concrètement</span>
      <h2 class="section-title">Les types de parrainage</h2>
      <p class="section-subtitle" style="margin:0 auto">
        Chaque parrainage a un impact direct et mesurable sur la vie d'un enfant.
      </p>
    </div>

    <div class="grid-3" style="margin-bottom:2.5rem">
      <!-- Repas -->
      <a href={`${BASE}/parrainage-repas`} class="card">
        <Img src={`${BASE}/assets/images/Repas.png`} alt="Parrainage repas — un repas chaque jour" class="card-img" width={400} height={250} loading="lazy" style="object-fit:contain;background:#FEF3C7;padding:1rem" />
        <div class="card-body">
          <span class="card-tag">Repas quotidien</span>
          <div class="parain-price" style="font-size:2rem;margin-bottom:0.25rem">26€ <span style="font-size:0.9rem">/mois</span></div>
          <p class="card-desc">
            Offrez un repas chaud complet du lundi au samedi. Pour certains enfants,
            ce sera le seul repas de la journée.
          </p>
          <div class="card-arrow">En savoir plus <span>→</span></div>
        </div>
      </a>

      <!-- Études -->
      <a href={`${BASE}/parrainage-etudes`} class="card">
        <Img src={`${BASE}/assets/images/IMG_20221103_114325-1-1024x768.jpg`} alt="Scolarité financée — parrainage études" class="card-img" width={400} height={300} loading="lazy" />
        <div class="card-body">
          <span class="card-tag">Scolarité</span>
          <div class="parain-price" style="font-size:2rem;margin-bottom:0.25rem">35€+ <span style="font-size:0.9rem">/mois</span></div>
          <p class="card-desc">
            Financez la scolarité d'un enfant — accompagnement pédagogique, lycée,
            études supérieures.
          </p>
          <div class="card-arrow">En savoir plus <span>→</span></div>
        </div>
      </a>

      <!-- Maîtresse -->
      <a href={`${BASE}/parrainage-maitresse`} class="card">
        <Img src={`${BASE}/assets/images/IMG_20221104_115245-768x1024.jpg`} alt="Institutrice soutenue — parrainage maîtresse" class="card-img" width={400} height={533} loading="lazy" />
        <div class="card-body">
          <span class="card-tag">Enseignement</span>
          <div class="parain-price" style="font-size:2rem;margin-bottom:0.25rem">25€ <span style="font-size:0.9rem">/mois</span></div>
          <p class="card-desc">
            Soutenez une institutrice des casitas — garantissez un encadrement
            pédagogique de qualité.
          </p>
          <div class="card-arrow">En savoir plus <span>→</span></div>
        </div>
      </a>
    </div>

    <div style="text-align:center">
      <a href={`${BASE}/devenir-parrain`} class="btn-red">Devenir parrain ou marraine</a>
    </div>
  </div>
</section>

<!-- ══ GALLERY + CAROUSEL ═══════════════════════════════════════ -->
<section class="section bg-stone">
  <div class="section-inner">
    <div style="margin-bottom:2rem;display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:1rem">
      <div>
        <span class="section-tag">Sur le terrain</span>
        <h2 class="section-title" style="margin-bottom:0">Nos actions en images</h2>
      </div>
      <a href={`${BASE}/dernieres-nouvelles`} class="btn-red" style="font-size:0.85rem">Toutes les nouvelles →</a>
    </div>

    <!-- Carousel terrain -->
    <div
      class="carousel-wrap"
      style="margin-bottom:1rem"
      role="region"
      aria-roledescription="carousel"
      aria-label="Galerie photos — actions sur le terrain"
    >
      <div class="carousel-track" aria-live="off">
        <div class="carousel-slide" role="group" aria-roledescription="slide" aria-label="1 sur 6" aria-hidden="false">
          <Img src={`${BASE}/assets/images/IMG_20221105_191530-FOTO-LISTA-PADRINOS-1024x460.jpg`} alt="Novembre 2022 — La liste des parrains et marraines" width={1024} height={460} loading="eager" />
          <div class="carousel-caption" aria-hidden="true">Novembre 2022 — La liste des parrains et marraines</div>
        </div>
        <div class="carousel-slide" role="group" aria-roledescription="slide" aria-label="2 sur 6" aria-hidden="true">
          <Img src={`${BASE}/assets/images/IMG_20221103_121345-1-1024x768.jpg`} alt="Mission terrain — Collique, Lima" width={1024} height={768} />
          <div class="carousel-caption" aria-hidden="true">Mission terrain — Collique, Lima</div>
        </div>
        <div class="carousel-slide" role="group" aria-roledescription="slide" aria-label="3 sur 6" aria-hidden="true">
          <Img src={`${BASE}/assets/images/IMG_20221104_102402-768x1024.jpg`} alt="Les enfants des casitas" width={768} height={1024} />
          <div class="carousel-caption" aria-hidden="true">Les enfants des casitas</div>
        </div>
        <div class="carousel-slide" role="group" aria-roledescription="slide" aria-label="4 sur 6" aria-hidden="true">
          <Img src={`${BASE}/assets/images/IMG_20221103_173649-1024x768.jpg`} alt="Activités avec les enfants" width={1024} height={768} />
          <div class="carousel-caption" aria-hidden="true">Activités avec les enfants</div>
        </div>
        <div class="carousel-slide" role="group" aria-roledescription="slide" aria-label="5 sur 6" aria-hidden="true">
          <Img src={`${BASE}/assets/images/IMG_20221104_115950-1024x768.jpg`} alt="Repas quotidien au Comedor" width={1024} height={768} />
          <div class="carousel-caption" aria-hidden="true">Repas quotidien au Comedor</div>
        </div>
        <div class="carousel-slide" role="group" aria-roledescription="slide" aria-label="6 sur 6" aria-hidden="true">
          <Img src={`${BASE}/assets/images/IMG-20231223-WA0015-2-770x1024.jpg`} alt="Décembre 2023 — Nouvelles de Collique" width={770} height={1024} />
          <div class="carousel-caption" aria-hidden="true">Décembre 2023 — Nouvelles de Collique</div>
        </div>
      </div>
      <button class="carousel-btn carousel-btn-prev" aria-label="Diapositive précédente">‹</button>
      <button class="carousel-btn carousel-btn-next" aria-label="Diapositive suivante">›</button>
      <div class="carousel-dots" role="tablist" aria-label="Sélectionner une diapositive">
        <button class="carousel-dot active" role="tab" aria-label="Diapositive 1" aria-selected="true"></button>
        <button class="carousel-dot" role="tab" aria-label="Diapositive 2" aria-selected="false"></button>
        <button class="carousel-dot" role="tab" aria-label="Diapositive 3" aria-selected="false"></button>
        <button class="carousel-dot" role="tab" aria-label="Diapositive 4" aria-selected="false"></button>
        <button class="carousel-dot" role="tab" aria-label="Diapositive 5" aria-selected="false"></button>
        <button class="carousel-dot" role="tab" aria-label="Diapositive 6" aria-selected="false"></button>
      </div>
    </div>

    <!-- Mosaique photos -->
    <div class="mosaic" aria-label="Galerie photos du Pérou" role="list">
      <div class="mosaic-large mosaic-item" role="listitem">
        <Img src={`${BASE}/assets/images/reg-cus-ville001-1280x800.jpeg`} alt="Lima — Vue de la capitale du Pérou" width={1280} height={800} />
      </div>
      <div class="mosaic-item" role="listitem">
        <Img src={`${BASE}/assets/images/received_1757209797774632-1024x768.jpeg`} alt="Équipe bénévole de l'association" width={1024} height={768} />
      </div>
      <div class="mosaic-item" role="listitem">
        <Img src={`${BASE}/assets/images/imgp2516.jpg`} alt="Enfants de Collique" width={600} height={450} />
      </div>
    </div>
  </div>
</section>

<!-- ══ CTA DON + HELLOASSO ═════════════════════════════════════ -->
<section class="section bg-white">
  <div class="section-inner">
    <div class="cta-banner">
      <h2>Votre générosité change des vies</h2>
      <p>
        Vos dons financent les repas quotidiens, la scolarité, les fournitures scolaires
        et les projets d'infrastructure. 100% de votre don est utilisé sur le terrain.
      </p>
      <div style="display:flex;gap:0.75rem;flex-wrap:wrap;justify-content:center">
        <a href={HELLOASSO_URL} target="_blank" rel="noopener noreferrer" class="btn-primary"><span aria-hidden="true">💚</span> Donner sur HelloAsso</a>
        <a href={`${BASE}/parrainage`} class="btn-secondary">Devenir parrain</a>
      </div>
    </div>
  </div>
</section>

<!-- ══ ACTUALITÉS snippet ════════════════════════════════════════ -->
<section class="section bg-cream">
  <div class="section-inner">
    <div style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:1rem;margin-bottom:2rem">
      <div>
        <span class="section-tag">Actualités</span>
        <h2 class="section-title" style="margin-bottom:0">Restez informés</h2>
      </div>
      <a href={`${BASE}/dernieres-nouvelles`} class="btn-red" style="font-size:0.85rem">Toutes les news →</a>
    </div>
    <div class="grid-3">
      <a href={`${BASE}/dernieres-nouvelles`} class="card">
        <Img src={`${BASE}/assets/images/IMG-20231223-WA0015-2-770x1024.jpg`} alt="Dernières nouvelles de Collique — décembre 2023" class="card-img" width={400} height={533} />
        <div class="card-body">
          <span class="card-tag">Terrain</span>
          <h3 class="card-title">Dernières nouvelles de Collique</h3>
          <p class="card-desc">Retrouvez toutes les actualités récentes de notre équipe au Pérou.</p>
          <div class="card-arrow">Lire →</div>
        </div>
      </a>
      <a href={`${BASE}/journaux`} class="card">
        <Img src={`${BASE}/assets/images/IMG_20221105_155745.jpg`} alt="Mission terrain — Novembre 2022" class="card-img" width={400} height={300} />
        <div class="card-body">
          <span class="card-tag">Publication</span>
          <h3 class="card-title">Nos journaux associatifs</h3>
          <p class="card-desc">Téléchargez nos bulletins d'information et les comptes rendus de missions.</p>
          <div class="card-arrow">Voir →</div>
        </div>
      </a>
      <a href={`${BASE}/benevolat`} class="card">
        <Img src={`${BASE}/assets/images/IMG_20191018_152356-1024x768.jpg`} alt="Mission bénévole au Pérou" class="card-img" width={400} height={300} />
        <div class="card-body">
          <span class="card-tag">Engagement</span>
          <h3 class="card-title">Partir en mission bénévole</h3>
          <p class="card-desc">Rejoignez-nous sur le terrain au Pérou ou participez en France.</p>
          <div class="card-arrow">Rejoindre →</div>
        </div>
      </a>
    </div>
  </div>
</section>

</MainLayout>

<style>
@media (max-width: 900px) {
  .section-inner > div[style*="grid-template-columns:1fr 1fr"] {
    grid-template-columns: 1fr !important;
  }
}
</style>
