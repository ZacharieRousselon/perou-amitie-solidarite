---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';

const pages = await getCollection('pages');
---

<MainLayout title="Accueil" description="Pérou Amitié Solidarité — Association humanitaire franco-péruvienne aidant les enfants défavorisés de Collique et de l'île d'Amantani.">

  <!-- Hero -->
  <section class="text-center py-12 md:py-16">
    <p class="text-red-700 font-semibold text-sm uppercase tracking-widest mb-4">Association humanitaire franco-péruvienne</p>
    <h1 class="text-4xl md:text-5xl font-bold text-stone-900 mb-6 leading-tight">
      Pérou Amitié Solidarité
    </h1>
    <p class="text-xl text-stone-600 max-w-2xl mx-auto mb-10 leading-relaxed">
      Depuis 2003, nous aidons les enfants défavorisés du bidonville de Collique et de l'île d'Amantani
      grâce à vos parrainages et vos dons.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/parrainage"
         class="bg-red-700 text-white px-8 py-3 rounded-full font-semibold hover:bg-red-600 transition-colors shadow">
        Devenir parrain
      </a>
      <a href="/don"
         class="bg-amber-500 text-white px-8 py-3 rounded-full font-semibold hover:bg-amber-400 transition-colors shadow">
        Faire un don
      </a>
    </div>
  </section>

  <!-- Chiffres clés -->
  <section class="grid grid-cols-1 sm:grid-cols-3 gap-6 my-10">
    {[
      { value: '130+', label: 'enfants parrainés', color: 'text-red-700' },
      { value: '2003', label: 'année de création', color: 'text-amber-600' },
      { value: '2', label: 'zones d\'action au Pérou', color: 'text-emerald-700' },
    ].map((stat) => (
      <div class="bg-white rounded-xl border border-stone-200 p-6 text-center shadow-sm">
        <p class={`text-4xl font-bold ${stat.color} mb-1`}>{stat.value}</p>
        <p class="text-stone-500 text-sm">{stat.label}</p>
      </div>
    ))}
  </section>

  <!-- Rubriques principales -->
  <section class="mt-14">
    <h2 class="text-2xl font-bold text-stone-800 mb-8">Explorer le site</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {[
        { slug: 'association',    title: "L'Association",  desc: "Notre histoire, notre equipe et nos valeurs humanitaires.",      icon: '🤝' },
        { slug: 'parrainage',     title: 'Parrainage',     desc: "Parrainer un enfant pour financer ses repas ou sa scolarite.",   icon: '❤️' },
        { slug: 'zone-collique',  title: 'Collique',       desc: "Notre principal terrain d'action au nord de Lima.",              icon: '🏘️' },
        { slug: 'zone-amantani',  title: 'Amantani',       desc: "Notre action sur l'ile d'Amantani, lac Titicaca.",               icon: '🏔️' },
        { slug: 'projets',        title: 'Nos Projets',    desc: "Eau potable, alimentation, education — nos projets en cours.",   icon: '🚰' },
        { slug: 'benevolat',      title: 'Benevolat',      desc: "Rejoignez-nous en France ou partez en mission au Perou.",        icon: '✈️' },
      ].map((item) => (
        <a href={`/perou-amitie-solidarite/${item.slug}`}
           class="group bg-white rounded-xl border border-stone-200 p-6 shadow-sm hover:shadow-md hover:border-red-300 transition-all duration-200">
          <div class="text-3xl mb-3">{item.icon}</div>
          <h3 class="font-semibold text-stone-900 group-hover:text-red-700 transition-colors mb-2">{item.title}</h3>
          <p class="text-stone-500 text-sm leading-relaxed">{item.desc}</p>
        </a>
      ))}
    </div>
  </section>


  <!-- CTA Don -->
  <section class="mt-16 bg-red-800 text-white rounded-2xl p-10 text-center">
    <h2 class="text-2xl font-bold mb-3">Soutenez notre mission</h2>
    <p class="text-red-200 mb-6 max-w-xl mx-auto">
      Vos dons permettent de financer les repas, la scolarité et les projets d'infrastructure au Pérou.
      Chaque euro compte.
    </p>
    <a href="/don"
       class="inline-block bg-amber-400 text-stone-900 font-bold px-10 py-3 rounded-full hover:bg-amber-300 transition-colors">
      Faire un don maintenant
    </a>
  </section>

</MainLayout>
